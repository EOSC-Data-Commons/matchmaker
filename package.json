{
  "name": "matchmaker-frontend",
  "private": true,
  "version": "0.5.0",
  "type": "module",
  "scripts": {
    "dev": "tsx server.ts",
    "build": "react-router build && tsc -p tsconfig.node.json --outDir dist",
    "start": "NODE_ENV=production node dist/server.js",
    "cluster": "pm2 start 'NODE_ENV=production node dist/server.js' --name matchmaker -i max",
    "stop": "pm2 stop matchmaker",
    "restart": "pm2 restart matchmaker",
    "logs": "pm2 logs matchmaker",
    "preview": "NODE_ENV=production tsx server.ts",
    "lint": "eslint ."
  },
  "dependencies": {
    "@radix-ui/react-toast": "^1.2.15",
    "@radix-ui/react-tooltip": "^1.2.8",
    "@react-router/fs-routes": "^7.13.0",
    "@react-router/node": "^7.13.0",
    "@react-router/serve": "^7.13.0",
    "@tailwindcss/vite": "^4.1.17",
    "@tanstack/react-query": "^5.90.20",
    "@types/compression": "^1.8.1",
    "@types/morgan": "^1.9.10",
    "class-variance-authority": "^0.7.1",
    "compression": "^1.8.1",
    "express": "^5.2.1",
    "http-proxy-middleware": "^3.0.5",
    "isbot": "^5.1.34",
    "lucide-react": "^0.563.0",
    "morgan": "^1.10.1",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-icons": "^5.5.0",
    "react-router": "^7.13.0",
    "react-router-dom": "^7.13.0",
    "tailwind-merge": "^3.4.0",
    "tailwindcss-animate": "^1.0.7",
    "tsx": "^4.21.0"
  },
  "devDependencies": {
