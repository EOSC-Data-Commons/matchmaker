{
  "name": "matchmaker-frontend",
  "private": true,
  "version": "0.9.0",
  "type": "module",
  "scripts": {
    "dev": "tsx server.ts",
    "clean": "rm -rf build",
    "build": "npm run clean && react-router build && esbuild server.ts --bundle --platform=node --format=esm --outfile=build/server.js --packages=external",
    "start": "NODE_ENV=production node build/server.js",
    "prod": "NODE_ENV=production pm2-runtime start build/server.js --name matchmaker -i max",
    "stop": "pm2 stop matchmaker",
    "restart": "pm2 restart matchmaker",
    "logs": "pm2 logs matchmaker",
    "preview": "NODE_ENV=production tsx server.ts",
    "lint": "eslint .",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "postversion": "if [ \"$(git rev-parse --abbrev-ref HEAD)\" = \"main\" ]; then git push --follow-tags origin HEAD; else echo \"Not on main branch, skipping push.\"; fi"
  },
  "dependencies": {
    "@bufbuild/protobuf": "^2.12.0",
    "@grpc/grpc-js": "^1.14.3",
    "@radix-ui/react-toast": "^1.2.15",
    "@radix-ui/react-tooltip": "^1.2.8",
    "@react-router/express": "^7.17.0",
    "@react-router/fs-routes": "^7.17.0",
    "@react-router/node": "^7.17.0",
    "@react-router/serve": "^7.17.0",
    "@tailwindcss/vite": "^4.3.0",
    "@tanstack/react-query": "^5.90.21",
    "class-variance-authority": "^0.7.1",
    "compression": "^1.8.1",
    "express": "^5.2.1",
    "http-proxy-middleware": "^3.0.5",
    "isbot": "^5.1.35",
    "jsonwebtoken": "^9.0.3",
    "lucide-react": "^0.563.0",
    "morgan": "^1.10.1",
    "pm2": "^7.0.1",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-icons": "^5.5.0",
    "react-is": "^19.2.7",
    "react-router": "^7.17.0",
    "recharts": "^3.8.1",
    "tailwind-merge": "^3.4.0",
    "tailwindcss-animate": "^1.0.7"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.1",
    "@react-router/dev": "^7.17.0",
    "@tailwindcss/postcss": "^4.1.17",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/compression": "^1.8.1",
    "@types/express": "^5.0.6",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/morgan": "^1.9.10",
    "@types/node": "^25.5.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react-swc": "^4.2.3",
    "@vitest/coverage-v8": "^4.1.9",
    "autoprefixer": "^10.4.24",
    "esbuild": "^0.28.1",
    "eslint": "^9.19.0",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.5.0",
    "eslint-plugin-react-you-might-not-need-an-effect": "^0.10.1",
    "globals": "^17.3.0",
    "grpc-tools": "^1.13.1",
    "happy-dom": "^20.10.6",
    "msw": "^2.14.6",
    "tailwindcss": "^4.3.0",
    "ts-proto": "^2.11.6",
    "tsx": "^4.22.3",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.36.0",
    "vite": "^7.3.2",
    "vitest": "^4.1.9"
  },
  "overrides": {
    "minimatch": "^10.2.1",
    "ws": "^8.21.0",
    "esbuild": "^0.28.1",
    "js-yaml": "^4.2.0"
  }
}
